{% set org = os.getenv("ASWF_PKG_ORG", "aswf") %}
[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=14.2
compiler.libcxx=libstdc++11
compiler.cppstd=20
build_type=Release
[options]
# Build everything as shared libs by default
*:shared=True
[tool_requires]
[replace_requires]
openssl/*: openssl/1.1.1k@{{ org }}/ci_common6
gnutls/*: gnutls/3.6.16@{{ org }}/ci_common6
[replace_tool_requires]
cmake/*: cmake/4.0.6@{{ org }}/ci_common6
ninja/*: ninja/1.13.2@{{ org }}/ci_common6
[platform_requires]
[buildenv]
GCC_INSTALL_DIR=/opt/rh/gcc-toolset-14/root/lib/gcc/x86_64-redhat-linux/14
