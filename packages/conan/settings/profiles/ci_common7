{% set org = os.getenv("ASWF_PKG_ORG", "aswf") %}
[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=14.2
compiler.libcxx=libstdc++11
compiler.cppstd=20
build_type=Release
[options]
# Build everything as shared libs by default
*:shared=True
[tool_requires]
[replace_requires]
openssl/*: openssl/3.5.5@{{ org }}/ci_common7
gnutls/*: gnutls/3.8.10@{{ org }}/ci_common7
[replace_tool_requires]
cmake/*: cmake/4.3.3@{{ org }}/ci_common7
ninja/*: ninja/1.13.2@{{ org }}/ci_common7
[platform_requires]
[buildenv]
GCC_INSTALL_DIR=/opt/rh/gcc-toolset-14/root/lib/gcc/x86_64-redhat-linux/14
