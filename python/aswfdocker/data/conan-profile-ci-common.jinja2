# !!! This file is automatically generated from a Jinja2 template.       !!!
# !!! Do not edit manually — run "aswfdocker dockergen" to regenerate.   !!!
{% set org = os.getenv("ASWF_PKG_ORG", "aswf") %}
[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=[[ versions.ASWF_GCC_VERSION ]]
compiler.libcxx=libstdc++11
compiler.cppstd=[[ versions.ASWF_CXX_STANDARD ]]
build_type=Release
[options]
# Build everything as shared libs by default
*:shared=True
[tool_requires]
[replace_requires]
openssl/*: openssl/[[ versions.ASWF_OPENSSL_VERSION ]]@{{ org }}/[[ conan_profile ]]
[replace_tool_requires]
cmake/*: cmake/[[ versions.ASWF_CMAKE_VERSION ]]@{{ org }}/[[ conan_profile ]]
ninja/*: ninja/[[ versions.ASWF_NINJA_VERSION ]]@{{ org }}/[[ conan_profile ]]
[platform_requires]
[buildenv]
GCC_INSTALL_DIR=/opt/rh/[[ versions.ASWF_DTS_PREFIX ]]-[[ versions.ASWF_DTS_VERSION ]]/root/lib/gcc/x86_64-redhat-linux/[[ versions.ASWF_DTS_VERSION ]]
